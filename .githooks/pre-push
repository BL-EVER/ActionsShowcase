#!/usr/bin/env bash
echo "[pre-push] starting..." >&2

set -e

# This hook may run under Git Bash (mingw, paths like /c/Program Files/...)
# OR under WSL (Linux, paths like /mnt/c/Program Files/...) depending on which
# bash the host git resolved via the shebang. Visual Studio 2026 picks WSL on
# some setups; the CLI/PowerShell path resolves to Git Bash. Handle both.
if grep -qi microsoft /proc/version 2>/dev/null; then
    WIN_C="/mnt/c"
else
    WIN_C="/c"
fi

DOTNET=""
for candidate in \
    "$WIN_C/Program Files/dotnet/dotnet.exe" \
    "$WIN_C/Program Files (x86)/dotnet/dotnet.exe" \
    "/c/Program Files/dotnet/dotnet.exe" \
    "/mnt/c/Program Files/dotnet/dotnet.exe" \
    "/c/Program Files (x86)/dotnet/dotnet.exe" \
    "/mnt/c/Program Files (x86)/dotnet/dotnet.exe"; do
    if [ -f "$candidate" ]; then
        DOTNET="$candidate"
        break
    fi
done

# Fallback to PATH lookup. WSL bash needs .exe spelled out; Git Bash doesn't.
if [ -z "$DOTNET" ]; then
    if command -v dotnet >/dev/null 2>&1; then
        DOTNET="dotnet"
    elif command -v dotnet.exe >/dev/null 2>&1; then
        DOTNET="dotnet.exe"
    fi
fi

if [ -z "$DOTNET" ]; then
    echo "[pre-push] dotnet not found." >&2
    echo "[pre-push] PATH=$PATH" >&2
    exit 1
fi

echo "[pre-push] using $DOTNET" >&2

echo "[pre-push] dotnet build (Release)..." >&2
"$DOTNET" build ActionsShowcase.slnx --configuration Release --nologo

echo "[pre-push] dotnet test (unit)..." >&2
"$DOTNET" test ActionsShowcase.Tests.Unit/ActionsShowcase.Tests.Unit.csproj \
    --no-build --configuration Release --nologo

echo "[pre-push] OK" >&2
